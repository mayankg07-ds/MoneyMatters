# Database (Railway / PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/moneymatters
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# Clerk JWT validation
# Get these from Clerk dashboard → API Keys
CLERK_JWK_SET_URI=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER_URI=https://your-clerk-domain.clerk.accounts.dev

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
